const grid=document.getElementById("staffGrid");

function getSavedPhoto(id){
return localStorage.getItem("staff_photo_"+id);
}

function savePhoto(id,data){
localStorage.setItem("staff_photo_"+id,data);
}

function renderStaff(list){

grid.innerHTML="";

list.forEach(s=>{

let initials=s.teacher.split(" ").map(n=>n[0]).join("").substring(0,2);

let savedPhoto=getSavedPhoto(s.sNo);

let avatarHTML=savedPhoto
? `<img src="${savedPhoto}">`
: initials;

let card=`
<div class="staff-card">

<div class="avatar" id="avatar_${s.sNo}">${avatarHTML}</div>

<div class="name">${s.teacher}</div>

<div class="role">${s.aLevel}</div>

<div class="info">Academic: ${s.trade || ""}</div>

<div class="info">Professional: ${s.pQuali || ""}</div>

<div class="email">${s.email || ""}</div>

<input class="upload-btn" type="file" accept="image/*" onchange="uploadPhoto(event,${s.sNo})">

</div>
`;

grid.innerHTML+=card;

});

}

function uploadPhoto(event,id){

const file=event.target.files[0];

if(!file) return;

const reader=new FileReader();

reader.onload=function(e){

savePhoto(id,e.target.result);

renderStaff(staff);

}

reader.readAsDataURL(file);

}

renderStaff(staff);


document.getElementById("search").addEventListener("keyup",function(){

let value=this.value.toLowerCase();

let filtered=staff.filter(t=>t.teacher.toLowerCase().includes(value));

renderStaff(filtered);

});

